{
  "name": "free-name-convention",
  "version": "3.1.0",
  "description": "Open-source file naming compliance guardian — Enforce international normative naming standards on your folders. Free forever.",
  "main": "src/main.js",
  "author": {
    "name": "Rafael França",
    "email": "rafael.franca@live.com",
    "url": "https://github.com/rfranca777"
  },
  "license": "MIT",
  "keywords": [
    "file-naming",
    "compliance",
    "normative",
    "guardian",
    "iso",
    "gdpr",
    "lgpd",
    "hipaa",
    "nfe",
    "electron",
    "desktop",
    "windows",
    "odefender"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "bugs": {
    "url": "https://github.com/rfranca777/FreeNameConvention/issues"
  },
  "homepage": "https://github.com/rfranca777/FreeNameConvention",
  "repository": {
    "type": "git",
    "url": "https://github.com/rfranca777/FreeNameConvention.git"
  },
  "scripts": {
    "start": "electron .",
    "start:service": "electron . --service",
    "build": "electron-builder --win --x64",
    "build:installer": "electron-builder --win --x64 --config.win.target=nsis",
    "lint": "echo \"No lint configured yet\""
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "nodemailer": "^8.0.1"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.freenameconvention.guardian",
    "productName": "FreeNameConvention",
    "copyright": "Copyright © 2026 FreeNameConvention Community — MIT License",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerSidebar": null,
      "license": "LICENSE"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "LICENSE",
      "README.md"
    ],
    "extraResources": [
      {
        "from": "scripts/",
        "to": "scripts/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "dist"
    }
  }
}
